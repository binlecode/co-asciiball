# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/

# Virtual environments
.venv/
venv/
env/

# Tooling caches
.ruff_cache/
.pytest_cache/

# Cloudflare Wrangler local cache/state (Pages deploys -- see
# docs/RUNBOOK-pages-publish.md). Regenerated per deploy; never committed. Auth
# credentials live globally in ~/Library/Preferences/.wrangler/, not here.
.wrangler/

# macOS
.DS_Store

# Scratch dir: everything under tmp/ is ignored -- working scripts, prototypes,
# and intermediate data alike. The shipped data/*.b64 blobs are the runtime
# source of truth; the offline gen_*/build_* regen scripts live here on disk
# (and in git history) but are intentionally not tracked.
tmp/

# Local Claude Code settings (per-developer)
.claude/settings.local.json
